         <dc:title>
            <rdf:Alt>
               <rdf:li xml:lang="x-default">Icone port bleu</rdf:li>
            </rdf:Alt>
         </dc:title>
         <dc:description>
            <rdf:Alt>
               <rdf:li xml:lang="x-default">Ship anchor vector icon set. Isolated marine icon vector design. Designed for web and app design interfaces.</rdf:li>
            </rdf:Alt>
         </dc:description>
         <dc:subject>
            <rdf:Bag>
               <rdf:li>ship</rdf:li>
               <rdf:li>sea</rdf:li>
